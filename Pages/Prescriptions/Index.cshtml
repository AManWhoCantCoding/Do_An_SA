@page
@model DocDocGo.Pages.Prescriptions.IndexModel
@{
    ViewData["Title"] = "Prescriptions";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Prescriptions</h2>
        <a asp-page="/Prescriptions/AddPrescription" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Prescription
        </a>
    </div>
    <table class="table table-hover table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Patient</th>
                <th>Medication</th>
                <th>Dosage</th>
                <th>Payment Needed</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="prescriptions-table-body">
            <tr><td colspan="7" class="text-center">Loading prescriptions via API...</td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/prescriptions.js" asp-append-version="true"></script>
}
